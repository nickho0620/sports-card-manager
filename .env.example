# ── Required ─────────────────────────────────────────────────────────────────
# Claude API key — get at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Cloud Deployment (required for Render) ───────────────────────────────────
# PostgreSQL — get free at https://neon.tech
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Cloudinary — get free at https://cloudinary.com (Dashboard → Account Details)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ── Optional ──────────────────────────────────────────────────────────────────
# Claude model for card analysis (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Database URL (default: local SQLite file — auto-detected)
# DATABASE_URL=sqlite:///./cards.db

# Upload directory for local mode (default: ./uploads)
# UPLOAD_DIR=./uploads
